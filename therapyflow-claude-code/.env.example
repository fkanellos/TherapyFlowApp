# TherapyFlow Backend — Environment Variables
# Copy to .env for local development (never commit .env)
# See: docs/deployment.md for production setup

DATABASE_URL=jdbc:postgresql://localhost:5432/therapyflow
DATABASE_USER=therapyflow
DATABASE_PASSWORD=therapyflow

# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_random_hex
JWT_ISSUER=therapyflow.io

# From Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Optional
PORT=8080
